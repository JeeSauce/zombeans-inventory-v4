# Zombeans Inventory environment variables
# Copy to .env.local for local development. Never commit real values.
# Vercel values must be configured separately for Preview and Production.

# Public: embedded in browser output. Use only the Supabase public/anon credential.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co" # Supabase project API URL.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key" # Public key; RLS remains mandatory.
NEXT_PUBLIC_SITE_URL="http://localhost:3000" # Canonical app origin; use the exact HTTPS origin in Vercel.

# Server-only: never prefix these with NEXT_PUBLIC_ and never expose them to client components.
SUPABASE_SERVICE_ROLE_KEY="your-server-only-service-role-key" # Bypasses RLS; server runtime only.
SUPABASE_DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres" # Local/CI integration tests only; do not set on the Vercel app.

# Transactional email. Console is local-development only; production must use Resend.
EMAIL_PROVIDER="console" # console (non-production) | resend (production); smtp is reserved/unimplemented.
EMAIL_FROM="Zombeans <no-reply@zombeans.xyz>" # Must use a provider-verified production domain.
RESEND_API_KEY="" # Required server-only secret when EMAIL_PROVIDER=resend.
E2E_ALLOW_CONSOLE_EMAIL="false" # Local Playwright only; never set in Vercel. Requires loopback Supabase.
SMTP_HOST="" # Reserved for a future SMTP adapter; not used by the current release.
SMTP_PORT="587" # Reserved for a future SMTP adapter.
SMTP_USER="" # Reserved for a future SMTP adapter.
SMTP_PASSWORD="" # Reserved for a future SMTP adapter.

# Step-up security. Use a distinct high-entropy pepper per environment.
STEPUP_CODE_PEPPER="replace-with-at-least-32-random-bytes" # Keys hashes for Super Admin codes.
STEPUP_CODE_TTL_SECONDS="300" # Verification-code lifetime in seconds.
STEPUP_MAX_ATTEMPTS="5" # Maximum guesses per code.
STEPUP_RATE_LIMIT_PER_HOUR="5" # Maximum code issues per account per hour.

# Application defaults.
APP_TIMEZONE="Asia/Manila" # Authoritative business timezone.
APP_DEFAULT_CURRENCY="PHP" # Display/default accounting currency.

# Future integration placeholder. Leave unset; Phase 10 has no live Loyverse API sync.
LOYVERSE_API_TOKEN=""
