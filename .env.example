# ─────────────────────────────────────────────────────────────────────────────
# Zombeans Inventory — Environment Variables
# Copy to .env.local (dev) and NEVER commit real values. See docs/SUPABASE_SETUP.md.
# Validated at boot by lib/env.ts (Zod). Missing/invalid values fail fast.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public (safe to expose to the browser) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Server-only (NEVER expose to the client) ────────────────────────────────
# Service-role key bypasses RLS. Used only in server runtime (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Transactional email for Super Admin step-up codes / notifications.
# Provider-agnostic; wire to Resend/SMTP. Leave blank in dev to use the console transport.
EMAIL_PROVIDER="console"            # console | resend | smtp
EMAIL_FROM="Zombeans <no-reply@zombeans.xyz>"
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Security tuning (sensible defaults in lib/env.ts if omitted)
STEPUP_CODE_TTL_SECONDS="300"       # ~5 minutes
STEPUP_MAX_ATTEMPTS="5"
STEPUP_RATE_LIMIT_PER_HOUR="5"

# App config
APP_TIMEZONE="Asia/Manila"
APP_DEFAULT_CURRENCY="PHP"

# ── V2 / future (leave blank in MVP) ────────────────────────────────────────
LOYVERSE_API_TOKEN=""
